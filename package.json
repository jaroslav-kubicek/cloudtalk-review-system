{
  "name": "ct-reviews-system",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "lint": "oxlint .",
    "typecheck": "pnpm -r typecheck",
    "dev:api": "pnpm --filter @reviews/api start:dev",
    "dev:web": "pnpm --filter @reviews/web dev"
  },
  "devDependencies": {
    "oxlint": "^1.0.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "esbuild"
    ]
  }
}
